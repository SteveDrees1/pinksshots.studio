{
  "name": "pinkshots.studio",
  "version": "0.2.0",
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "es5-ext",
      "esbuild",
      "unrs-resolver"
    ],
    "overrides": {
      "glob": "^11.0.0",
      "rimraf": "^5.0.0",
      "tar": "^7.0.0"
    }
  },
  "scripts": {
    "dev": "./infrastructure/scripts/dev.sh",
    "dev:web": "pnpm --filter @pinkshots/web dev",
    "dev:admin": "pnpm --filter @pinkshots/admin dev",
    "dev:api": "pnpm --filter @pinkshots/api dev",
    "build": "./infrastructure/scripts/build.sh",
    "lint": "pnpm -r run lint",
    "clean": "./infrastructure/scripts/clean.sh",
    "start": "./infrastructure/scripts/start.sh",
    "run": "./infrastructure/scripts/run.sh",
    "full": "./infrastructure/scripts/full.sh",
    "docker:ensure": "./infrastructure/scripts/ensure-docker.sh",
    "docker:up": "docker-compose -f infrastructure/docker/docker-compose.yml up -d",
    "docker:down": "docker-compose -f infrastructure/docker/docker-compose.yml down",
    "docker:reset": "docker-compose -f infrastructure/docker/docker-compose.yml down -v && docker-compose -f infrastructure/docker/docker-compose.yml up -d",
    "db:migrate": "pnpm -C apps/api db:migrate",
    "db:seed": "pnpm -C apps/api db:seed",
    "db:studio": "pnpm -C apps/api db:studio",
    "db:generate": "pnpm -C apps/api db:generate",
    "test": "pnpm exec vitest run --config apps/api/vitest.config.ts && pnpm exec vitest run --config apps/web/vitest.config.ts && pnpm exec vitest run --config apps/admin/vitest.config.ts",
    "test:all": "pnpm test && pnpm run test:health",
    "test:health": "node infrastructure/scripts/test-health.js"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^25.0.1",
    "pnpm": "^9.15.9",
    "vitest": "^2.1.9"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
