# Copy to .env and fill in. Never commit .env.

# Database (use docker: pnpm docker:up)
DATABASE_URL=postgresql://pinkshots:pinkshots@localhost:5432/pinkshots

# Session signing (min 32 chars, generate with: openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-secure-random-string

# Origins for CORS and cookies
ADMIN_ORIGIN=http://localhost:3001
WEB_ORIGIN=http://localhost:3000

# API base URL (used by web/admin to fetch data)
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

NODE_ENV=development
